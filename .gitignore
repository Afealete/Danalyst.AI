# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Node.js / package manager
node_modules/
**/node_modules/
artifacts/**/node_modules/
.pnpm-store/
.pnp.*
package-lock.json
yarn.lock
npm-debug.log
pnpm-debug.log
yarn-error.log
git
# Artifact workspace outputs
.artifacts/**/node_modules/
.artifacts/**/build/

# Build outputs
dist/
build/
out-tsc/
*.tsbuildinfo
coverage/
.tmp/

# Python
dvenv/
venv/
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.mypy_cache/
.pytest_cache/
.python-version

# Environment files
backend/**/.env
.env
.env.*

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# System files
.DS_Store
Thumbs.db

# Misc
.sass-cache/
.cache/
.local/
/connect.lock
/libpeerconnection.log
/typings

# Optional git files
# Keep any source-managed GitHub config or instructions
!.github/
